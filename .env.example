### Customization
# Brand Name
VITE_BRAND_NAME=
# Brand Logo URL
VITE_LOGO_SRC=https://raw.githubusercontent.com/Issei-177013/public-assets-main/main/icons/starvpn.png
# Support URL
VITE_SUPPORT_URL=https://t.me/YourID
# Feature Toggles
VITE_OFF_SECTIONS={"appsBox": true, "logoBox": true, "timeBox": true, "usageBox": true, "userBox": true, "supportBox": false, "configs": false}
# Apps JSON URL
VITE_JSON_APPS_URL=https://raw.githubusercontent.com/Issei-177013/public-assets-main/main/json/os.json


### Host Settings
# Host URL 
VITE_PANEL_DOMAIN=https://panel.example.com:8000
